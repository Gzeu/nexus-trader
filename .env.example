# ── MODE ────────────────────────────────────────────────────────────────────
DRY_RUN=true
TESTNET=true
LOG_LEVEL=INFO
ENV=development

# ── BINANCE ─────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_secret_here
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision
BINANCE_BASE_URL=https://api.binance.com

# ── RISK ─────────────────────────────────────────────────────────────────────
MAX_POSITIONS=3
RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
MAX_DRAWDOWN=0.12
MIN_RR=1.5
COOLDOWN_MINUTES=15
MAX_CONSECUTIVE_LOSSES=3

# ── EXECUTION ────────────────────────────────────────────────────────────────
ORDER_TIMEOUT_SECONDS=10
MAX_RETRIES=3
RETRY_BASE_DELAY=0.5
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0

# ── TELEGRAM ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── DB ───────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./journal.db

# ── SYMBOLS ──────────────────────────────────────────────────────────────────
SPOT_WHITELIST=BTCUSDT,ETHUSDT
FUTURES_WHITELIST=BTCUSDT,ETHUSDT
DEFAULT_LEVERAGE=5
