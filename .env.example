# =============================================================================
# Nexus Trader — Environment Configuration
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ──────────────────────────────────────────────────────────────────────
# ENVIRONMENT  — development | staging | production
# ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ──────────────────────────────────────────────────────────────────────
# BINANCE — get testnet keys at https://testnet.binance.vision/
# ──────────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
TESTNET=true
DRY_RUN=true

# Optional: separate futures testnet keys (falls back to above if empty)
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=

# ──────────────────────────────────────────────────────────────────────
# TRADING MODE
# ──────────────────────────────────────────────────────────────────────
MARKET_MODE=spot
FUTURES_ENABLED=false
DEFAULT_LEVERAGE=1

# ──────────────────────────────────────────────────────────────────────
# SYMBOLS
# ──────────────────────────────────────────────────────────────────────
SYMBOLS=BTCUSDT,ETHUSDT
SYMBOL_WHITELIST=BTCUSDT,ETHUSDT
SYMBOL_BLACKLIST=

# ──────────────────────────────────────────────────────────────────────
# RISK
# ──────────────────────────────────────────────────────────────────────
RISK_PER_TRADE=0.01
MAX_POSITIONS=5
MAX_DAILY_LOSS=0.03
MAX_DRAWDOWN=0.12
MIN_RR=1.5
COOLDOWN_MINUTES=20
MAX_CONSECUTIVE_LOSSES=3
ATR_MAX_PCT=0.05
SPREAD_MAX_PCT=0.002

# ──────────────────────────────────────────────────────────────────────
# AUTOMATION
# ──────────────────────────────────────────────────────────────────────
AUTOMATION_INTERVAL_SEC=60
STRATEGY_INTERVAL_SECONDS=60
STRATEGY_TIMEFRAME=15m

# ──────────────────────────────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────
# JOURNAL
# ──────────────────────────────────────────────────────────────────────
JOURNAL_CSV_PATH=journal/trades.csv
JOURNAL_DB_PATH=journal/trades.db

# ──────────────────────────────────────────────────────────────────────
# TELEGRAM (optional)
# ──────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────────────────────────────
# REDIS (optional — used for idempotency keys; in-memory fallback if empty)
# ──────────────────────────────────────────────────────────────────────
REDIS_URL=
