# ─── EXCHANGE ─────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
TESTNET=true
DRY_RUN=true

# ─── MODE ─────────────────────────────────────────────────────────────────────
MARKET_MODE=spot           # spot | futures
FUTURES_ENABLED=false
DEFAULT_LEVERAGE=1         # futures only

# ─── RISK ─────────────────────────────────────────────────────────────────────
RISK_PER_TRADE=0.01        # 1% equity per trade
MAX_POSITIONS=5
MAX_DAILY_LOSS=0.03        # 3% daily loss → auto-pause
MAX_DRAWDOWN=0.12          # 12% drawdown → emergency stop
MIN_RR=1.5                 # minimum reward:risk ratio
COOLDOWN_MINUTES=20        # minutes after SL hit
MAX_CONSECUTIVE_LOSSES=3   # pause after N losses in a row

# ─── VOLATILITY FILTERS ───────────────────────────────────────────────────────
ATR_MAX_PCT=0.05           # skip if ATR% > 5%
SPREAD_MAX_PCT=0.002       # skip if spread > 0.2%

# ─── EXECUTION ────────────────────────────────────────────────────────────────
ORDER_TIMEOUT_SEC=10
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=0.5
RETRY_MAX_DELAY=8.0
EXCHANGE_INFO_TTL_SECONDS=1800
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=30.0

# ─── AUTOMATION ───────────────────────────────────────────────────────────────
AUTOMATION_INTERVAL_SEC=60
STRATEGY_INTERVAL_SECONDS=60
STRATEGY_TIMEFRAME=15m
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
SYMBOL_WHITELIST=BTCUSDT,ETHUSDT
SYMBOL_BLACKLIST=

# ─── JOURNAL ──────────────────────────────────────────────────────────────────
JOURNAL_CSV_PATH=journal/trades.csv
JOURNAL_DB_PATH=journal/trades.db

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── REDIS (optional — idempotency keys cache) ────────────────────────────────
REDIS_URL=

# ─── SERVER ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change_me_in_production

# ─── LOGGING ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
