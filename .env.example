# ─────────────────────────────────────────────────────────────────────────────
# Nexus Trader v3 – Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Binance Spot (Testnet) ────────────────────────────────────────────────────
BINANCE_API_KEY=your_testnet_spot_api_key
BINANCE_API_SECRET=your_testnet_spot_api_secret

# ── Binance Futures (Testnet, optional) ───────────────────────────────────────
BINANCE_FUTURES_API_KEY=your_testnet_futures_api_key
BINANCE_FUTURES_API_SECRET=your_testnet_futures_api_secret

# ── Environment ───────────────────────────────────────────────────────────────
TESTNET=true            # true=testnet, false=mainnet LIVE TRADING
DRY_RUN=true            # true=simulate orders (no real fills)
DEBUG=false
ENVIRONMENT=development # development | staging | production

# ── Market Modes ──────────────────────────────────────────────────────────────
FUTURES_ENABLED=false

# ── Symbol Configuration ──────────────────────────────────────────────────────
SPOT_WHITELIST=BTCUSDT,ETHUSDT,BNBUSDT
FUTURES_WHITELIST=BTCUSDT,ETHUSDT
SYMBOL_BLACKLIST=
LEVERAGE_DEFAULT=1       # 1 for spot, 1-125 for futures
PRIMARY_TIMEFRAME=15m

# Per-symbol JSON overrides (optional):
# SYMBOL_CONFIG={"BTCUSDT":{"leverage":3,"max_position_pct":0.05},"ETHUSDT":{"leverage":2}}
SYMBOL_CONFIG={}

# ── Risk Parameters ───────────────────────────────────────────────────────────
RISK_PER_TRADE=0.01      # 0.001–0.05 (1% default)
MAX_POSITIONS=3
MAX_DAILY_LOSS=0.03      # 3% of equity
MAX_WEEKLY_LOSS=0.07     # 7% of equity
MAX_DRAWDOWN=0.12        # 12% drawdown → emergency stop
MIN_RR=1.5               # minimum reward:risk ratio
COOLDOWN_MINUTES=15
MAX_CONSECUTIVE_LOSSES=3
MIN_CONFIDENCE=0.60
MIN_CONSENSUS=0.55

# ── ATR Volatility Filter ──────────────────────────────────────────────────────
ATR_PERIOD=14
ATR_MULTIPLIER_SL=1.5
ATR_MULTIPLIER_TP=2.5
MAX_ATR_PCT=0.05         # skip signals if ATR > 5% of price

# ── Execution ─────────────────────────────────────────────────────────────────
ORDER_TIMEOUT_SECONDS=30
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=30.0
EXCHANGE_INFO_TTL_SECONDS=1800
PARTIAL_CLOSE_TP1_PCT=0.40
PARTIAL_CLOSE_TP2_PCT=0.40

# ── Scan / Automation ─────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=60
RECONCILE_INTERVAL_SECONDS=300
MAX_HOLDING_HOURS=72.0
INACTIVITY_HOURS=24.0

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-to-something-long-and-random-in-production
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Telegram Alerts ───────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Redis (optional idempotency) ──────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nexus_trader.db
JOURNAL_CSV_PATH=./journal/trades.csv
