# =============================================================================
# Nexus Trader — Environment Configuration
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ──────────────────────────────────────────────────────────────────────
# ENVIRONMENT  — development | staging | production
# ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ──────────────────────────────────────────────────────────────────────
# PRODUCTION FLAG
# ⚠️  IMPORTANT: Seteaza IS_PRODUCTION=true inainte de orice deploy live!
#    IS_PRODUCTION=false expune /docs si /redoc cu toate endpoint-urile.
#    IS_PRODUCTION=true dezactiveaza /docs, /redoc si /openapi.json.
#    Default: false (safe pentru development/testnet — NU lasa false pe prod!)
# ──────────────────────────────────────────────────────────────────────
IS_PRODUCTION=false

# ──────────────────────────────────────────────────────────────────────
# BINANCE — get testnet keys at https://testnet.binance.vision/
# ──────────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
TESTNET=true
DRY_RUN=true

# Optional: separate futures testnet keys (falls back to above if empty)
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=

# ──────────────────────────────────────────────────────────────────────
# TRADING MODE
# ──────────────────────────────────────────────────────────────────────
MARKET_MODE=spot
FUTURES_ENABLED=false
DEFAULT_LEVERAGE=1
FUTURES_LEVERAGE=1

# ──────────────────────────────────────────────────────────────────────
# SYMBOLS
# ──────────────────────────────────────────────────────────────────────
SYMBOLS=BTCUSDT,ETHUSDT
SYMBOL_WHITELIST=BTCUSDT,ETHUSDT
SYMBOL_BLACKLIST=

# ──────────────────────────────────────────────────────────────────────
# RISK
# ──────────────────────────────────────────────────────────────────────
RISK_PER_TRADE=0.01
MAX_POSITIONS=5
MAX_DAILY_LOSS=0.03
MAX_DRAWDOWN=0.12
MIN_RR=1.5
COOLDOWN_MINUTES=20
MAX_CONSECUTIVE_LOSSES=3
ATR_MAX_PCT=0.05
SPREAD_MAX_PCT=0.002

# ──────────────────────────────────────────────────────────────────────
# TRADE EXIT PARAMETERS
# MAX_HOLDING_HOURS: inchide fortat pozitia dupa N ore (TIME_EXIT)
# INACTIVITY_HOURS: inchide daca pretul nu progreseaza dupa N ore
# TP1_FRACTION: fractia din pozitie inchisa la TP1 (0.40 = 40%)
# TP2_FRACTION: fractia din remainder inchisa la TP2
# TRAIL_PCT: trailing stop procentual (ignorat daca ATR e disponibil)
# SIGNAL_CLOSE_MIN_CONFIDENCE: confidence minim pentru SIGNAL_CLOSE
# ──────────────────────────────────────────────────────────────────────
MAX_HOLDING_HOURS=72
INACTIVITY_HOURS=24
TP1_FRACTION=0.40
TP2_FRACTION=0.40
TRAIL_PCT=0.015
SIGNAL_CLOSE_MIN_CONFIDENCE=0.75

# ──────────────────────────────────────────────────────────────────────
# AUTOMATION
# ──────────────────────────────────────────────────────────────────────
AUTOMATION_INTERVAL_SEC=60
STRATEGY_INTERVAL_SECONDS=60
SCAN_INTERVAL_SECONDS=60
STRATEGY_TIMEFRAME=15m
PRIMARY_TIMEFRAME=15m

# ──────────────────────────────────────────────────────────────────────
# EXECUTION / TIMEOUTS
# ORDER_TIMEOUT_SEC: timeout pentru place_order() in automation_engine.
#   Daca Binance nu raspunde in acest interval, tick-ul continua fara a bloca.
#   Recomandat: 10-20s (testnet poate fi mai lent, foloseste 20+).
# RECONCILE_TIMEOUT_SECONDS: timeout pentru reconcile() la startup.
#   Testnet Binance are latenta ridicata (300-800ms/req). Default 60s.
# EXCHANGE_INFO_TTL_SECONDS: cat timp sa cache-uiasca exchangeInfo (secunde).
# ──────────────────────────────────────────────────────────────────────
ORDER_TIMEOUT_SEC=15
RECONCILE_TIMEOUT_SECONDS=60
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=0.5
RETRY_MAX_DELAY=8.0
EXCHANGE_INFO_TTL_SECONDS=1800
MAX_RETRIES=3

# ──────────────────────────────────────────────────────────────────────
# WEBSOCKET
# WS_RECONNECT_DELAY: secunde asteptare inainte de reconectare dupa drop
# WS_PING_INTERVAL: interval ping pentru a mentine conexiunea activa
# ──────────────────────────────────────────────────────────────────────
WS_RECONNECT_DELAY=5
WS_PING_INTERVAL=30

# ──────────────────────────────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ──────────────────────────────────────────────────────────────────────
# JOURNAL
# ──────────────────────────────────────────────────────────────────────
JOURNAL_CSV_PATH=journal/trades.csv
JOURNAL_DB_PATH=journal/trades.db

# ──────────────────────────────────────────────────────────────────────
# TELEGRAM (optional)
# ──────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────────────────────────────
# REDIS (optional — used for idempotency keys; in-memory fallback if empty)
# ──────────────────────────────────────────────────────────────────────
REDIS_URL=

# ──────────────────────────────────────────────────────────────────────
# AI COPILOT (optional)
# Groq este provider-ul implicit (gratuit). Fallback la OpenAI daca groq_api_key e gol.
# AI_MODEL: override model name. Gol = llama-3.3-70b-versatile (Groq) / gpt-4o-mini (OpenAI)
# ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
AI_MODEL=
AI_ENABLED=false
