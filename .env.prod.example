# ============================================================
# PRODUCTION environment — copie în .env.prod și completează
# NICIODATĂ nu comite .env.prod în git!
# ============================================================

# ── Exchange ────────────────────────────────────────────────
BINANCE_API_KEY=REAL_KEY_HERE
BINANCE_API_SECRET=REAL_SECRET_HERE
TESTNET=false

# ── Safety (SCHIMBĂ ÎNAINTE DE LIVE!) ──────────────────────
DRY_RUN=false
TRADING_MODE=spot
# TRADING_MODE=futures  ← decomentează pentru futures

# ── Risk management ─────────────────────────────────────────
RISK_PER_TRADE=0.005          # 0.5% risc per trade (conservator la start)
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS=0.02           # 2% daily loss limit
MAX_DRAWDOWN=0.10             # 10% emergency stop
MIN_RR_RATIO=1.5
COOLDOWN_MINUTES=30
MAX_CONSECUTIVE_LOSSES=3

# ── Futures (doar dacă TRADING_MODE=futures) ────────────────
FUTURES_LEVERAGE=5
HEDGE_MODE=false

# ── Symbols whitelist ───────────────────────────────────────
ALLOWED_SYMBOLS=["BTCUSDT","ETHUSDT"]

# ── Automation intervals ────────────────────────────────────
SIGNAL_CHECK_INTERVAL_SECONDS=60
PORTFOLIO_SYNC_INTERVAL_SECONDS=300
TIMEFRAME=15m

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://:${REDIS_PASSWORD}@nexus-redis:6379/0
REDIS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Telegram alerts ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=CHAT_ID_HERE
TELEGRAM_ALERT_ON_FILL=true
TELEGRAM_ALERT_ON_SL=true
TELEGRAM_ALERT_ON_EMERGENCY=true

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── API Security ─────────────────────────────────────────────
API_KEY_HEADER=X-Nexus-Key
API_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32

# ── Journal / DB ─────────────────────────────────────────────
JOURNAL_BACKEND=sqlite
JOURNAL_PATH=/app/journal/trades.db
